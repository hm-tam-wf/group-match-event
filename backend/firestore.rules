rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid in ["3sY4NPL2UZPFlV4Y8q3Y3BvdT5w2", "tHN0gED97nS6KEmDBKO0SgJOiWJ3"];
    }

    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Cho dashboard liệt kê sự kiện qua collection group trên "meta"
    match /{path=**}/meta/{doc} {
      allow read: if isAdmin();
    }

    match /events/{eventId} {
      function cfg() { return get(/databases/$(database)/documents/events/$(eventId)/meta/config).data; }
      function cap() { return cfg().capacity; }
      // Sĩ số RIÊNG theo đội: meta/config.caps là map { "<emoji>": số }. Có cap riêng cho đội này ⇒ dùng nó,
      // không thì dùng sĩ số CHUNG capacity. (1 lần get qua `let` để không vượt giới hạn document-access của rules.)
      function capFor(icon) {
        let c = cfg();
        return (c.caps != null && icon in c.caps) ? c.caps[icon] : c.capacity;
      }

      match /meta/{doc} {
        allow read: if true;              // trang công khai cần đọc cấu hình sự kiện đang mở
        allow write: if isAdmin();        // write gồm cả delete -> admin xoá được khi xoá event
      }

      match /teams/{icon} {
        allow read: if true;
        allow create: if exists(/databases/$(database)/documents/events/$(eventId)/meta/config)
                      && request.resource.data.count == 1
                      && request.resource.data.names.size() == 1;
        allow update: if request.resource.data.icon == resource.data.icon
                      && request.resource.data.count <= capFor(icon)
                      && request.resource.data.names.size() == request.resource.data.count;
        allow delete: if isAdmin();       // <-- cần để clear / xoá
      }

      match /members/{pid} {
        allow get:    if true;
        allow list:   if isAdmin();       // <-- cần để admin liệt kê khi clear
        allow create: if request.resource.data.keys().hasOnly(['icon', 'at']);
        allow update: if false;
        allow delete: if isAdmin();       // <-- cần để clear / xoá
      }

      match /dedup_keys/{key} {
        allow get:    if true;
        allow list:   if isAdmin();       // <-- cần để admin liệt kê khi clear
        allow create: if request.resource.data.keys().hasOnly(['at']);
        allow update: if false;
        allow delete: if isAdmin();       // <-- cần để clear / xoá
      }

      // Đặt-chỗ TIỀN-JOIN: giữ MSNV NGAY khi điền form để KHÔNG tạo signup thứ hai cùng mã (trước cả khi
      // join). key = _dedupKey(<dedupField>) — chuẩn hoá GIỐNG dedup_keys. Doc chỉ { at } (KHÔNG chứa pid
      // → không lộ token dù key = MSNV dễ đoán). Chốt CỨNG vẫn là dedup_keys (ghi lúc JOIN); đây là chốt mềm.
      match /reg_keys/{key} {
        allow get:    if true;            // client transaction + cổng vào đọc theo key đã biết
        allow list:   if isAdmin();       // chỉ admin liệt kê khi clear; KHÔNG mở cho client (chống enumerate)
        allow create: if request.resource.data.keys().hasOnly(['at']);
        allow update: if false;
        // delete tự do: chủ đặt-chỗ TỰ NHẢ khi đổi/sửa MSNV (typo) để không khoá nhầm mã người khác. Stakes
        // thấp: chỉ chốt tiền-join; xoá chỗ chỉ "mở lại" mã (= như chưa giữ), không đụng dedup_keys/signups.
        allow delete: if true;
      }

      // Danh sách cho phép (allowlist): chỉ key có trong đây mới claim được khi meta/config.allowlistMode = true.
      // key = _dedupKey(<giá trị dedupField>) — chuẩn hoá GIỐNG HỆT dedup_keys để import & claim khớp tuyệt đối.
      match /allowlist/{key} {
        allow get:   if true;             // client transaction cần đọc theo key đã biết
        allow list:  if isAdmin();        // chỉ admin liệt kê/đếm; KHÔNG mở cho client (chống enumerate)
        allow write: if isAdmin();        // admin import từ Excel; client không ghi
      }

      match /signups/{pid} {
        allow read:   if isAdmin();       // (list/count cho admin)
        allow create: if true;            // ghi hồ sơ NGAY khi điền xong (kể cả CHƯA chọn đội)
        // update: gắn đội khi join / sửa lại hồ sơ của chính mình. Chỉ cho khi GIỮ NGUYÊN playerId
        // (không đổi danh tính bản ghi). pid là token ngẫu nhiên, signups khoá đọc → không enumerate được.
        allow update: if request.resource.data.playerId == resource.data.playerId;
        // delete tự do: chủ bản ghi TỰ DỌN signup trùng của mình khi MSNV hoá ra đã có người join
        // (đụng độ pre-join). An toàn: signups KHOÁ ĐỌC + pid là token ngẫu nhiên → chỉ chủ (biết
        // pid của chính mình) mới xoá được, không ai enumerate/đoán pid người khác. Admin vẫn xoá được.
        allow delete: if true;
      }
    }

    match /{document=**} { allow read, write: if false; }
  }
}