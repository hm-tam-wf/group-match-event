rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid in ["3sY4NPL2UZPFlV4Y8q3Y3BvdT5w2", "tHN0gED97nS6KEmDBKO0SgJOiWJ3"];
    }

    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Cho dashboard liệt kê sự kiện qua collection group trên "meta"
    match /{path=**}/meta/{doc} {
      allow read: if isAdmin();
    }

    match /events/{eventId} {
      function cfg() { return get(/databases/$(database)/documents/events/$(eventId)/meta/config).data; }
      function cap() { return cfg().capacity; }

      match /meta/{doc} {
        allow read: if true;              // trang công khai cần đọc cấu hình sự kiện đang mở
        allow write: if isAdmin();        // write gồm cả delete -> admin xoá được khi xoá event
      }

      match /teams/{icon} {
        allow read: if true;
        allow create: if exists(/databases/$(database)/documents/events/$(eventId)/meta/config)
                      && request.resource.data.count == 1
                      && request.resource.data.names.size() == 1;
        allow update: if request.resource.data.icon == resource.data.icon
                      && request.resource.data.count == resource.data.count + 1
                      && request.resource.data.count <= cap()
                      && request.resource.data.names.size() == request.resource.data.count;
        allow delete: if isAdmin();       // <-- cần để clear / xoá
      }

      match /members/{pid} {
        allow get:    if true;
        allow list:   if isAdmin();       // <-- cần để admin liệt kê khi clear
        allow create: if request.resource.data.keys().hasOnly(['icon', 'at']);
        allow update: if false;
        allow delete: if isAdmin();       // <-- cần để clear / xoá
      }

      match /dedup_keys/{key} {
        allow get:    if true;
        allow list:   if isAdmin();       // <-- cần để admin liệt kê khi clear
        allow create: if request.resource.data.keys().hasOnly(['at']);
        allow update: if false;
        allow delete: if isAdmin();       // <-- cần để clear / xoá
      }

      match /signups/{pid} {
        allow read:   if isAdmin();       // (list/count cho admin)
        allow create: if true;            // ghi hồ sơ NGAY khi điền xong (kể cả CHƯA chọn đội)
        // update: gắn đội khi join / sửa lại hồ sơ của chính mình. Chỉ cho khi GIỮ NGUYÊN playerId
        // (không đổi danh tính bản ghi). pid là token ngẫu nhiên, signups khoá đọc → không enumerate được.
        allow update: if request.resource.data.playerId == resource.data.playerId;
        allow delete: if isAdmin();       // <-- cần để clear / xoá
      }
    }

    match /{document=**} { allow read, write: if false; }
  }
}